generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Source {
  id         String   @id @default(cuid())
  name       String   @unique
  type       String   @default("website")
  trustScore Float    @default(1.0)
  createdAt  DateTime @default(now())

  votes Vote[]
}

model Subject {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  battlesAsA     Battle[]        @relation("BattleSubjectA")
  battlesAsB     Battle[]        @relation("BattleSubjectB")
  votes          Vote[]
  signalSnapshot SignalSnapshot?

  @@index([category])
}

model Battle {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  category   String
  subjectAId String
  subjectBId String
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subjectA Subject @relation("BattleSubjectA", fields: [subjectAId], references: [id])
  subjectB Subject @relation("BattleSubjectB", fields: [subjectBId], references: [id])
  votes    Vote[]

  @@index([category])
  @@index([subjectAId])
  @@index([subjectBId])
}

model Vote {
  id          String   @id @default(cuid())
  battleId    String
  subjectId   String
  sourceId    String
  anonymousId String
  createdAt   DateTime @default(now())

  battle  Battle  @relation(fields: [battleId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  source  Source  @relation(fields: [sourceId], references: [id])

  @@unique([battleId, anonymousId])
  @@index([subjectId])
  @@index([battleId])
  @@index([createdAt])
}

model BattleApproval {
  id                 String    @id @default(cuid())
  slug               String    @unique
  status             String    // "approved" | "rejected" | "needs_changes"
  note               String?
  approvedBy         String?
  approvedAt         DateTime?
  publishedBy        String?
  publishedAt        DateTime?
  republishedAt      DateTime?
  publishedWebsiteAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model SignalSnapshot {
  id           String   @id @default(cuid())
  subjectId    String   @unique
  score        Float    @default(0)
  confidence   Float    @default(0)
  trend        Float    @default(0)
  totalSignals Int      @default(0)
  battleCount  Int      @default(0)
  updatedAt    DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id])
}
